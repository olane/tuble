{
  "name": "tuble-tmp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --exclude '**/*.all-pairs.test.ts' --exclude '**/node_modules/**'",
    "test:watch": "vitest --exclude '**/*.all-pairs.test.ts' --exclude '**/node_modules/**'",
    "test:all-pairs": "vitest run src/game/pathfinding.all-pairs.test.ts",
    "test:visual": "vitest run tests/visual",
    "test:visual:update": "UPDATE_VISUAL_BASELINES=1 vitest run tests/visual",
    "fetch-tfl": "tsx scripts/fetch-tfl.ts",
    "build-data": "tsx scripts/build-data.ts",
    "build-icons": "tsx scripts/build-icons.ts"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vitest": "^4.1.3"
  }
}
